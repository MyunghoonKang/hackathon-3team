# 공동 계약 (H+0~2) · 각자 로컬에서 `.env` 로 복사 후 값 채워 쓴다.
# .env 는 반드시 .gitignore 에 포함 — 커밋 금지.

# ── Plan A (3A 소유) ────────────────────────────────────────────────
PORT=3000
DB_PATH=data/sqlite.db
GAMES_DIR=games

# ── Plan B (4A · 4B 소유) ───────────────────────────────────────────
# Vault 마스터키. 생성: `openssl rand -hex 32`
VAULT_MASTER_KEY=

# mock  : Playwright 목업 HTML 만 사용 (기본값)
# dryrun: 실 ERP 까지 진입하되 최종 [상신] 은 스킵
# live  : 실 ERP 로 전체 플로우 · B14 한정
WORKER_MODE=mock

ERP_BASE_URL=https://erp.meissa.ai
ERP_COMPANY_CODE=meissa

# ── 실 상신 허용 플래그 (B14 데모 당일만 세팅) ──────────────────────────
# WORKER_MODE=live AND ERP_CONFIRM_SUBMIT=1 동시 세팅 + 사용자 동석 확인 후에만
# 워커가 최종 [상신] 버튼을 클릭한다. 데모 종료 즉시 주석 처리 / 삭제 필수.
# ERP_CONFIRM_SUBMIT=1
